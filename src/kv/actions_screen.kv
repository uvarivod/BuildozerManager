#:kivy 2.3.1
#:import dp kivy.metrics.dp
#:import LogPanel src.screens.log_panel.LogPanel
#:import ActionCard src.screens.action_card.ActionCard

<ActionsScreen>:
    log_panel: log_panel
    scenario_spinner: scenario_spinner
    profile_spinner: profile_spinner
    profile_btn: profile_btn
    chain_container: chain_container
    BoxLayout:
        orientation: 'vertical'
        padding: '10dp'
        spacing: '8dp'
        BoxLayout:
            size_hint_y: None
            height: '36dp'
            spacing: '6dp'
            Spinner:
                id: profile_spinner
                text: 'Select profile'
                size_hint_x: None
                width: '200dp'
                on_text: root.on_profile_spinner_text(self.text)
            Button:
                text: 'Delete'
                size_hint_x: None
                width: '60dp'
                background_color: 0.8, 0.2, 0.2, 1
                on_release: root.delete_profile()
            Label:
                text: ''
                size_hint_x: 1
            Button:
                id: profile_btn
                text: 'Select a profile'
                size_hint_x: None
                width: '110dp'
                on_release: root.on_profile_btn()
            Button:
                text: 'Scenarios'
                size_hint_x: None
                width: '100dp'
                disabled: root.is_running
                on_release: root.open_scenario_editor()
            Button:
                text: 'Settings'
                size_hint_x: None
                width: '80dp'
                disabled: root.is_running
                on_release: root.open_settings()
            Button:
                text: '?'
                size_hint_x: None
                width: '30dp'
                on_release: root.show_help()
        Label:
            text: root.status_label
            bold: True
            size_hint_y: None
            height: '24dp'
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '36dp'
            spacing: '10dp'
            Label:
                text: 'Scenarios'
                bold: True
                size_hint_x: None
                width: '80dp'
            Spinner:
                id: scenario_spinner
                text: 'Select scenario'
                size_hint_x: 0.4
                size_hint_y: None
                height: '36dp'
                on_text: root.on_scenario_selected(self.text)
            BoxLayout:
                orientation: 'horizontal'
                size_hint_x: None
                width: '250dp'
                spacing: '2dp'
                BoxLayout:
                CheckBox:
                    active: root.allow_separate_execution
                    on_active: setattr(root, 'allow_separate_execution', args[1])
                Label:
                    text: 'Allow running separately'
                    size_hint_x: None
                    width: '200dp'
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

        ScrollView:
            size_hint_y: None
            height: '140dp'
            do_scroll_x: True
            do_scroll_y: False
            BoxLayout:
                id: chain_container
                orientation: 'horizontal'
                size_hint_x: None
                spacing: '4dp'
                padding: [dp(4), dp(4)]
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '40dp'
            spacing: '10dp'
            Button:
                text: 'Run Scenario'
                size_hint_x: None
                width: '160dp'
                background_color: 0.2, 0.6, 0.2, 1
                disabled: root.is_running or not root.scenario_spinner or root.scenario_spinner.text == 'Select scenario'
                on_release: root.run_scenario()
            Button:
                text: 'Cancel'
                size_hint_x: None
                width: '120dp'
                background_color: 0.8, 0.2, 0.2, 1
                disabled: not root.is_running
                on_release: root.cancel_action()
        LogPanel:
            id: log_panel
