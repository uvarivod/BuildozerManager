#:kivy 2.3.1

<LogPanel>:
    log_display: log_label
    log_scroll: log_scroll
    BoxLayout:
        orientation: 'vertical'
        spacing: 4
        BoxLayout:
            size_hint_y: None
            height: 36
            spacing: 8
            padding: [8, 4]
            Label:
                text: 'Duration: ' + root.duration_label
                size_hint_x: None
                width: 200
                halign: 'left'
            Widget:
            Button:
                text: 'Clear'
                size_hint_x: None
                width: 80
                on_release: root.clear_log()
            Button:
                text: 'Save Log'
                size_hint_x: None
                width: 100
                on_release: root.save_log()
        ScrollView:
            id: log_scroll
            do_scroll_x: False
            do_scroll_y: True
            bar_width: 10
            scroll_type: ['bars', 'content']
            bar_color: 0.3, 0.6, 0.9, 0.8
            bar_inactive_color: 0.3, 0.6, 0.9, 0.3
            TextInput:
                id: log_label
                readonly: True
                font_name: 'RobotoMono-Regular'
                font_size: 11
                size_hint_y: None
                height: max(self.minimum_height, log_scroll.height)
                padding: [8, 4, 8, 4]
                background_color: 0, 0, 0, 0
                foreground_color: 0.9, 0.9, 0.9, 1
