#:kivy 2.3.1

<ProfileEditorScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 10
        spacing: 8
        BoxLayout:
            size_hint_y: None
            height: 36
            spacing: 8
            Button:
                text: '< Back'
                size_hint_x: None
                width: 80
                on_release: root.manager.current = 'actions'
            Label:
                text: 'Profile: ' + root.profile_name
                bold: True
        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 8
                BoxLayout:
                    size_hint_y: None
                    height: 30
                    spacing: 8
                    Label:
                        text: 'Name'
                        size_hint_x: None
                        width: 120
                    TextInput:
                        text: root.profile_name
                        on_text: root.profile_name = self.text
                        multiline: False
                BoxLayout:
                    size_hint_y: None
                    height: 30
                    spacing: 8
                    Label:
                        text: 'Source Dir'
                        size_hint_x: None
                        width: 120
                    TextInput:
                        text: root.sourcedir
                        on_text: root.sourcedir = self.text
                        multiline: False
                    Button:
                        text: 'Detect'
                        size_hint_x: None
                        width: 60
                        on_release: root.auto_detect_spec()
                BoxLayout:
                    size_hint_y: None
                    height: 30
                    spacing: 8
                    Label:
                        text: 'Spec Path'
                        size_hint_x: None
                        width: 120
                    TextInput:
                        text: root.spec_path
                        on_text: root.spec_path = self.text
                        multiline: False
                BoxLayout:
                    size_hint_y: None
                    height: 30
                    spacing: 8
                    Label:
                        text: 'ADB Path'
                        size_hint_x: None
                        width: 120
                    TextInput:
                        text: root.adb_path
                        on_text: root.adb_path = self.text
                        multiline: False
                    Button:
                        text: 'Auto'
                        size_hint_x: None
                        width: 60
                        on_release: root.auto_detect_adb()
                BoxLayout:
                    size_hint_y: None
                    height: 30
                    spacing: 8
                    Label:
                        text: 'WSL Dir'
                        size_hint_x: None
                        width: 120
                    TextInput:
                        text: root.wsl_dir
                        on_text: root.wsl_dir = self.text
                        multiline: False
                BoxLayout:
                    size_hint_y: None
                    height: 30
                    spacing: 8
                    Label:
                        text: 'WSL Distro'
                        size_hint_x: None
                        width: 120
                    TextInput:
                        text: root.wsl_distro
                        on_text: root.wsl_distro = self.text
                        multiline: False
                Label:
                    text: 'Excluded Files (one per line)'
                    size_hint_y: None
                    height: 20
                TextInput:
                    size_hint_y: None
                    height: 80
                    text: '\\n'.join(root.excluded_files)
                    on_text: root.excluded_files = self.text.split('\\n')
                Label:
                    text: 'Delete Exclusions (one per line)'
                    size_hint_y: None
                    height: 20
                TextInput:
                    size_hint_y: None
                    height: 80
                    text: '\\n'.join(root.delete_exclusions)
                    on_text: root.delete_exclusions = self.text.split('\\n')
                BoxLayout:
                    size_hint_y: None
                    height: 40
                    spacing: 8
                    Button:
                        text: 'Save'
                        on_release: root.save_profile()
                    Button:
                        text: 'Detect Spec'
                        on_release: root.auto_detect_spec()
