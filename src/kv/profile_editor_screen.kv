#:kivy 2.3.1
#:import dp kivy.metrics.dp

<ProfileEditorScreen>:
    name_input: name_input
    sourcedir_input: sourcedir_input
    spec_path_input: spec_path_input
    adb_path_input: adb_path_input
    wsl_dir_input: wsl_dir_input
    wsl_distro_input: wsl_distro_input
    excluded_files_input: excluded_files_input
    patches_container: patches_container
    delete_exclusions_input: delete_exclusions_input
    BoxLayout:
        orientation: 'vertical'
        padding: '10dp'
        spacing: '8dp'
        ScrollView:
            GridLayout:
                cols: 2
                spacing: '8dp'
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(0), dp(0), dp(0), dp(60)]
                Label:
                    text: 'Name'
                    size_hint_y: None
                    height: '32dp'
                TextInput:
                    id: name_input
                    size_hint_y: None
                    height: '32dp'
                    multiline: False
                Label:
                    text: 'Source Directory'
                    size_hint_y: None
                    height: '32dp'
                BoxLayout:
                    spacing: '4dp'
                    size_hint_y: None
                    height: '32dp'
                    TextInput:
                        id: sourcedir_input
                        multiline: False
                    Button:
                        text: 'Browse'
                        size_hint_x: None
                        width: '80dp'
                        on_release: root._browse_sourcedir()
                Label:
                    text: 'buildozer.spec path'
                    size_hint_y: None
                    height: '32dp'
                BoxLayout:
                    spacing: '4dp'
                    size_hint_y: None
                    height: '32dp'
                    TextInput:
                        id: spec_path_input
                        multiline: False
                    Button:
                        text: 'Browse'
                        size_hint_x: None
                        width: '80dp'
                        on_release: root._browse_spec_path()
                Label:
                    text: 'ADB path'
                    size_hint_y: None
                    height: '32dp'
                BoxLayout:
                    spacing: '4dp'
                    size_hint_y: None
                    height: '32dp'
                    TextInput:
                        id: adb_path_input
                        multiline: False
                    Button:
                        text: 'Browse'
                        size_hint_x: None
                        width: '80dp'
                        on_release: root._browse_adb_path()
                    Button:
                        text: 'Check'
                        size_hint_x: None
                        width: '80dp'
                        on_release: root._check_adb()
                Label:
                    text: 'Excluded files and directories (comma-sep)'
                    size_hint_y: None
                    height: '32dp'
                TextInput:
                    id: excluded_files_input
                    size_hint_y: None
                    height: '32dp'
                    multiline: False
                Label:
                    text: 'Patches'
                    size_hint_y: None
                    height: '32dp'
                    valign: 'middle'
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: '2dp'
                    padding: [dp(4), dp(4)]
                    canvas.before:
                        Color:
                            rgba: 0.2, 0.2, 0.2, 0.3
                        Rectangle:
                            size: self.size
                            pos: self.pos
                    Label:
                        text: 'Select patches to use with this profile:'
                        font_size: '11sp'
                        color: (0.7, 0.7, 0.7, 1)
                        size_hint_y: None
                        height: '20dp'
                        halign: 'left'
                        text_size: self.width, None
                    BoxLayout:
                        id: patches_container
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: '2dp'
                BoxLayout:
                    size_hint_y: None
                    height: '32dp'
                    canvas.before:
                        Color:
                            rgba: 0.15, 0.35, 0.6, 0.15
                        Rectangle:
                            size: self.size
                            pos: self.pos
                    Label:
                        text: 'WSL Related Configuration'
                        bold: True
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        padding: [dp(10), dp(0)]
                BoxLayout:
                    size_hint_y: None
                    height: '32dp'
                    canvas.before:
                        Color:
                            rgba: 0.15, 0.35, 0.6, 0.15
                        Rectangle:
                            size: self.size
                            pos: self.pos
                Label:
                    text: 'WSL Build Directory'
                    size_hint_y: None
                    height: '32dp'
                BoxLayout:
                    spacing: '4dp'
                    size_hint_y: None
                    height: '32dp'
                    TextInput:
                        id: wsl_dir_input
                        multiline: False
                    Button:
                        text: 'Browse'
                        size_hint_x: None
                        width: '80dp'
                        on_release: root._browse_wsl_dir()
                Label:
                    text: 'WSL Distribution'
                    size_hint_y: None
                    height: '32dp'
                TextInput:
                    id: wsl_distro_input
                    size_hint_y: None
                    height: '32dp'
                    multiline: False

                Label:
                    text: 'Retain During Sync (comma-sep)'
                    size_hint_y: None
                    height: '32dp'
                TextInput:
                    id: delete_exclusions_input
                    size_hint_y: None
                    height: '32dp'
                    multiline: False
        BoxLayout:
            size_hint_y: None
            height: '48dp'
            spacing: '10dp'
            padding: [dp(0), dp(8)]
            Button:
                text: '?'
                size_hint_x: None
                width: '30dp'
                on_release: root.show_help()
            Button:
                text: 'Cancel'
                on_release: root.cancel()
            Button:
                text: 'Save'
                id: save_btn
                background_color: 0.2, 0.6, 0.2, 1
                on_release: root.save()
