#:kivy 2.3.1

<ProfileListScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 10
        spacing: 10
        BoxLayout:
            size_hint_y: None
            height: 48
            spacing: 8
            Button:
                text: 'Add'
                size_hint_x: None
                width: 80
                on_release: root.add_profile()
            Button:
                text: 'Delete'
                size_hint_x: None
                width: 80
                on_release: root.delete_selected()
        RecycleView:
            id: profile_list
            viewclass: 'ProfileListItem'
            RecycleBoxLayout:
                default_size: None, 36
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: 4
